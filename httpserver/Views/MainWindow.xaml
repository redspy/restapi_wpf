<Window x:Class="httpserver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HTTP Server" Height="520" Width="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">

        <!-- Top Control Panel -->
        <Border DockPanel.Dock="Top"
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel>

                <!-- Port + Start/Stop -->
                <DockPanel>
                    <Label Content="Port:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsPortEditable}"
                             Width="80" VerticalAlignment="Center"
                             Padding="4,2" Margin="0,0,8,0"/>
                    <Button Content="{Binding StartStopLabel}"
                            Command="{Binding StartStopCommand}"
                            Width="90" Height="28"
                            Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2ECC71"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>

                <!-- Status + URL -->
                <DockPanel Margin="0,8,0,0">
                    <Label Content="Status:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                    <Label Content="{Binding StatusText}" FontWeight="Bold" VerticalAlignment="Center" Padding="0"
                           AutomationProperties.AutomationId="StatusLabel">
                        <Label.Style>
                            <Style TargetType="Label">
                                <Setter Property="Foreground" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Foreground" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Label.Style>
                    </Label>
                    <Label Content="{Binding UrlText}"
                           Foreground="#555555" Margin="12,0,0,0"
                           VerticalAlignment="Center" Padding="0"/>
                </DockPanel>

            </StackPanel>
        </Border>

        <!-- Bottom Bar -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <Button Content="Clear Log" Width="90" Height="26"
                    Command="{Binding ClearLogCommand}"/>
            <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScroll}"
                      VerticalAlignment="Center" Margin="12,0,0,0"/>
            <Label Content="{Binding RequestCount, StringFormat={}{0} requests}"
                   HorizontalAlignment="Right" DockPanel.Dock="Right"
                   VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Log Header -->
        <Label DockPanel.Dock="Top" Content="Request Log:"
               FontWeight="SemiBold" Padding="0,0,0,2"/>

        <!-- Request Log -->
        <ListBox x:Name="LogListBox"
                 ItemsSource="{Binding LogEntries}"
                 DisplayMemberPath="."
                 FontFamily="Consolas" FontSize="12"
                 Background="#F9F9F9"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

    </DockPanel>
</Window>
