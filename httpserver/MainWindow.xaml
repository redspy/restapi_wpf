<Window x:Class="httpserver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HTTP Server" Height="520" Width="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">

        <!-- 상단 컨트롤 영역 -->
        <Border DockPanel.Dock="Top"
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel>

                <!-- 포트 + 시작/중지 버튼 -->
                <DockPanel>
                    <Label Content="Port:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                    <TextBox x:Name="PortTextBox"
                             Width="80" Text="8080"
                             VerticalAlignment="Center"
                             Padding="4,2" Margin="0,0,8,0"/>
                    <Button x:Name="ToggleButton"
                            Content="Start" Width="90" Height="28"
                            Click="ToggleButton_Click"
                            Background="#2ECC71" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"/>
                </DockPanel>

                <!-- 상태 표시 -->
                <DockPanel Margin="0,8,0,0">
                    <Label Content="Status:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                    <Label x:Name="StatusLabel"
                           Content="Stopped"
                           Foreground="Red" FontWeight="Bold"
                           VerticalAlignment="Center" Padding="0"/>
                    <Label x:Name="UrlLabel"
                           Content=""
                           Foreground="#555555"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" Padding="0"/>
                </DockPanel>

            </StackPanel>
        </Border>

        <!-- 하단 바 -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
            <Button Content="Clear Log" Width="90" Height="26"
                    Click="ClearLog_Click"/>
            <CheckBox x:Name="AutoScrollCheckBox"
                      Content="Auto-scroll" IsChecked="True"
                      VerticalAlignment="Center" Margin="12,0,0,0"/>
            <Label x:Name="RequestCountLabel"
                   Content="0 requests"
                   HorizontalAlignment="Right"
                   DockPanel.Dock="Right"
                   VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 로그 헤더 -->
        <Label DockPanel.Dock="Top"
               Content="Request Log:"
               FontWeight="SemiBold"
               Padding="0,0,0,2"/>

        <!-- 요청 로그 -->
        <ListBox x:Name="LogListBox"
                 FontFamily="Consolas" FontSize="12"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 Background="#F9F9F9"/>

    </DockPanel>
</Window>
